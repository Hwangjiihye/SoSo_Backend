<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.soso.domain.member.dao.MemberDAO">

    <!-- 1. users 테이블 인서트 (useGeneratedKeys 적용) -->
    <insert id="insertUser" parameterType="com.soso.domain.member.dto.SignUpDto" useGeneratedKeys="true" keyProperty="userSeq">
        INSERT INTO users (
            user_id,
            password,
            name,
            nickname,
            email,
            phone,
            user_type
        ) VALUES (
            #{userId},
            #{password},
            #{name},
            #{nickname},
            #{email},
            #{phone},
            #{userType}
        )
    </insert>

    <!-- 2. stores 테이블 인서트 (store_image 컬럼 및 파라미터 제거) -->
    <insert id="insertStore" parameterType="com.soso.domain.member.dto.SignUpDto">
        INSERT INTO stores (
            user_seq,
            biz_number,
            company_name,
            ceo_name,
            opening_date,
            zonecode,
            address1,
            address2
        ) VALUES (
            #{userSeq},
            #{bizNo},
            #{corpName},
            #{repName},
            #{formattedOpenDate},
            #{zipCode},
            #{address},
            #{detailAddress}
        )
    </insert>

    <!-- 4. 매장 정보 선삭제 -->
    <delete id="deleteStoresByKey" parameterType="int">
        DELETE FROM stores WHERE user_seq = #{userSeq}
    </delete>

    <!-- 5. 계정 정보 후삭제 -->
    <delete id="deleteUser" parameterType="int">
        DELETE FROM users WHERE user_seq = #{userSeq}
    </delete>

    <!-- 중복 체크 쿼리 -->
    <select id="countByUserId" parameterType="string" resultType="int">
        SELECT COUNT(*) FROM users WHERE user_id = #{userId}
    </select>

    <select id="countByNickname" parameterType="string" resultType="int">
        SELECT COUNT(*) FROM users WHERE nickname = #{nickname}
    </select>

    <select id="countByEmail" parameterType="string" resultType="int">
        SELECT COUNT(*) FROM users WHERE email = #{email}
    </select>

    <select id="countByBizNo" parameterType="string" resultType="int">
        SELECT COUNT(*) FROM stores WHERE biz_number = #{bizNo}
    </select>

</mapper>
