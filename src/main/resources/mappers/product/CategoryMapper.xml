<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.soso.mappers.product.CategoryMapper">

    <select id="selectAllCategories" resultType="com.soso.domain.product.dto.CategoryDTO">
        SELECT 
            category_seq AS categorySeq, 
        category_name AS categoryName
        FROM categories
        ORDER BY category_seq ASC
    </select>

</mapper>
